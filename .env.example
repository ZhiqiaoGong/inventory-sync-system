PORT=3000
DB_PATH=./inventory.db
NODE_ENV=development

# =========================
# Platform mode
# mock = use built-in mock orders; runs the full flow without any Shopify / Etsy credentials (default)
# live = call the real platform APIs; requires the Shopify / Etsy config below
# =========================
PLATFORM_MODE=mock

# =========================
# Shopify config
# =========================
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxx
SHOPIFY_APP_CLIENT_SECRET=your_shopify_app_client_secret
SHOPIFY_API_VERSION=2025-10
SHOPIFY_LOCATION_ID=123456789

# =========================
# Etsy config
# Note: this uses the simplified "already have an access token" approach.
# For production you may also need to handle OAuth token refresh yourself.
# =========================
ETSY_API_BASE=https://openapi.etsy.com/v3/application
ETSY_ACCESS_TOKEN=your_etsy_access_token
ETSY_SHOP_ID=12345678

# =========================
# Sync behavior
# =========================
ENABLE_PLATFORM_PUSH=true
DEFAULT_LOW_STOCK_THRESHOLD=10

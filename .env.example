PORT=3000
DB_PATH=./inventory.db
NODE_ENV=development

# =========================
# Platform mode
# mock = use built-in mock orders; runs the full flow without any Shopify / Etsy credentials (default)
# live = call the real platform APIs; requires the Shopify / Etsy config below
# =========================
PLATFORM_MODE=mock

# =========================
# Shopify config
# =========================
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxx
SHOPIFY_APP_CLIENT_SECRET=your_shopify_app_client_secret
SHOPIFY_API_VERSION=2025-10
SHOPIFY_LOCATION_ID=123456789

# Secret used to verify X-Shopify-Hmac-Sha256 on POST /webhooks/shopify.
# In live mode this comes from your Shopify webhook configuration; in mock mode
# any value works (scripts/sendMockWebhook.js signs with the same secret).
SHOPIFY_WEBHOOK_SECRET=mock-webhook-secret

# =========================
# Etsy config
# Note: this uses the simplified "already have an access token" approach.
# For production you may also need to handle OAuth token refresh yourself.
# =========================
ETSY_API_BASE=https://openapi.etsy.com/v3/application
ETSY_ACCESS_TOKEN=your_etsy_access_token
ETSY_SHOP_ID=12345678

# =========================
# Sync behavior
# =========================
ENABLE_PLATFORM_PUSH=true
DEFAULT_LOW_STOCK_THRESHOLD=10

# Write-back retry pipeline: failed pushes retry with exponential backoff
# (base * 2^attempt) until PUSH_MAX_ATTEMPTS, then move to the dead-letter
# queue (GET /push-jobs/dead-letter).
PUSH_RETRY_BASE_MS=5000
PUSH_MAX_ATTEMPTS=5

# Mock mode only: probability (0..1) that a mock write-back fails with a
# simulated 503, to exercise the retry / dead-letter pipeline locally.
MOCK_PUSH_FAILURE_RATE=0
